# ============================================================
# LUMINA AI v4.0 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Chat Integration (Required for AI features)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Redis (optional — falls back to DiskCache if not configured)
REDIS_URL=redis://localhost:6379/0

# Storage
UPLOAD_DIR=./uploads
CACHE_DIR=./cache
MAX_FILE_SIZE_MB=500

# Logging
LOG_LEVEL=INFO

# ── Midnight Blockchain ──────────────────────────────────────
MIDNIGHT_NETWORK=testnet
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300
MIDNIGHT_IDENTITY_SALT=nexus_midnight_identity_v1_secure
BLOCKCHAIN_LEDGER_PATH=./blockchain_ledger.json
ZK_PROVING_KEY=nexus_midnight_proving_key_v1
ZK_VERIFYING_KEY=nexus_midnight_verifying_key_v1
