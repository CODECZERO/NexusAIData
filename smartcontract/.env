# ========================================================
# NexusAIData — Midnight Network Configuration
# ========================================================

# ── Network Selection ──────────────────────────────────
# Options: preprod, mainnet, local, undeployed
MIDNIGHT_NETWORK=preprod

# ── Midnight Preprod Endpoints (Official v4 API) ───────
# Source: https://docs.midnight.network
MIDNIGHT_INDEXER_URL=https://indexer.preprod.midnight.network/api/v4/graphql
MIDNIGHT_INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
# IMPORTANT: Proof server must run LOCALLY via Docker.
# Run: npm run start-proof-server
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300

# ── Wallet Configuration ──────────────────────────────
# Generate via: Lace wallet → Settings → Recovery Phrase
# CAUTION: Never commit real seed phrases to version control
MIDNIGHT_WALLET_SEED="foster grass double tired spin witness goose license topple dutch garlic ride social receive shift hollow when beach twelve hurdle remember wall lamp absent"

# ── Contract Addresses (populated after deployment) ────
# Run `npm run deploy` to populate these
# NOTE: Keys use SINGLE underscore (CONTRACT_X) to match config.ts
CONTRACT_DATA_FINGERPRINT_ADDRESS=0x616464723a3a4461746146696e6765727072696e
CONTRACT_DATA_BOUNTY_ADDRESS=0x616464723a3a44617461426f756e7479
CONTRACT_AUDIT_PROOF_ADDRESS=0x616464723a3a417564697450726f6f66
CONTRACT_PLATFORM_ESCROW_ADDRESS=0x616464723a3a506c6174666f726d457363726f77

# ── Cryptographic Salts ───────────────────────────────
MIDNIGHT_IDENTITY_SALT=nexus_midnight_identity_v1_secure
ZK_PROVING_KEY=nexus_midnight_proving_key_v1
ZK_VERIFYING_KEY=nexus_midnight_verifying_key_v1

# ── Local State Encryption ────────────────────────────
MIDNIGHT_PRIVATE_STATE_PASSWORD="nexus-ai-secure-storage-password-2026"

# ── Platform Escrow ──────────────────────────────────
PLATFORM_ESCROW_ADDRESS=mn_addr_preprod1zqh2l3amclj6td546zmsmxqwd6685svayucq3n7cs73539zgtrps3tctqc

# ── Frontend VITE Proxies ────────────────────────────
VITE_CONTRACT_DATA_FINGERPRINT_ADDRESS=0x616464723a3a4461746146696e6765727072696e
VITE_CONTRACT_DATA_BOUNTY_ADDRESS=0x616464723a3a44617461426f756e7479
VITE_CONTRACT_AUDIT_PROOF_ADDRESS=0x616464723a3a417564697450726f6f66
VITE_CONTRACT_PLATFORM_ESCROW_ADDRESS=0x616464723a3a506c6174666f726d457363726f77

CONTRACT__PLATFORM_ESCROW_ADDRESS=0x616464723a3a506c6174666f726d457363726f77

CONTRACT__DATA_FINGERPRINT_ADDRESS=0x616464723a3a4461746146696e6765727072696e
CONTRACT__DATA_BOUNTY_ADDRESS=0x616464723a3a44617461426f756e7479
CONTRACT__AUDIT_PROOF_ADDRESS=0x616464723a3a417564697450726f6f66
