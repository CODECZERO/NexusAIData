# ========================================================
# NexusAIData — Midnight Network Configuration
# ========================================================

# ── Network Selection ──────────────────────────────────
# Options: undeployed, testnet, mainnet, local
MIDNIGHT_NETWORK=undeployed

# ── Midnight Undeployed (Local) Endpoints ──────────────
MIDNIGHT_INDEXER_URL=http://localhost:8088/api/v4/graphql
MIDNIGHT_INDEXER_WS_URL=ws://localhost:8088/api/v4/graphql/ws
MIDNIGHT_NODE_URL=http://localhost:9944
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300
MIDNIGHT_BRIDGE_URL=http://localhost:3001

# ── Wallet Configuration ──────────────────────────────
# Generate via: Lace wallet → Settings → Recovery Phrase
# CAUTION: Never commit real seed phrases to version control
MIDNIGHT_WALLET_SEED=test test test test test test test test test test test junk

# ── Contract Addresses (populated after deployment) ────
# Run `npm run deploy:testnet` to populate these
CONTRACT_DATA_FINGERPRINT_ADDRESS=
CONTRACT_DATA_BOUNTY_ADDRESS=
CONTRACT_AUDIT_PROOF_ADDRESS=

# ── Cryptographic Salts ───────────────────────────────
MIDNIGHT_IDENTITY_SALT=nexus_midnight_identity_v1_secure
ZK_PROVING_KEY=nexus_midnight_proving_key_v1
ZK_VERIFYING_KEY=nexus_midnight_verifying_key_v1
